{
  "functions": {
    "app/api/**/*.js": {
      "maxDuration": 30
    }
  },
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "crons": [{
    "path": "/api/cron/process-transfers",
    "schedule": "0 * * * *"
  }]
}