{
  "name": "bluetubetv",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analytics:realtime": "node scripts/analytics-realtime.js", 
    "lint": "next lint",
    
    "// Deployment Commands": "",
    "deploy": "npm run build && vercel --prod",
    "deploy:preview": "vercel",
    "logs": "vercel logs --follow",
    
    "// Analytics Commands": "",
    "analytics:revenue": "node scripts/check-revenue.js",
    "analytics:weekly": "node scripts/weekly-report.js",
    
    "// Blockchain Commands": "",
    "blockchain:balance": "node scripts/check-contract.js",
    "blockchain:withdraw": "node scripts/withdraw-fees.js",
    "blockchain:test": "node scripts/test-superchat.js",
    
    "// Database Commands": "",
    "db:migrate": "npx supabase db push",
    "db:seed": "node scripts/seed-database.js",
    "db:reset": "npx supabase db reset",
    
    "// Stripe Commands": "",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe",
    "stripe:test": "stripe trigger payment_intent.succeeded",
    "stripe:balance": "stripe balance",
    
    "// Testing Commands": "",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:payments": "node scripts/test-payments.js",
    
    "// Utility Commands": "",
    "clean": "rm -rf .next node_modules",
    "fresh": "npm run clean && npm install && npm run dev",
    "check": "npm run lint && npm run build"
  },
  "dependencies": {
    "next": "14.0.0",
    "react": "^18",
    "react-dom": "^18",
    "ethers": "^5.7.2",
    "stripe": "^14.0.0",
    "@supabase/supabase-js": "^2.38.0",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.9.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "eslint": "^8",
    "eslint-config-next": "14.0.0"
  }
}